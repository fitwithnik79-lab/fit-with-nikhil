{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform, either an admin or a client.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "client"] },
        "displayName": { "type": "string" },
        "programGoals": { "type": "string", "description": "Client's fitness goals" },
        "programDetails": { "type": "string", "description": "Details about the client's current program" },
        "height": { "type": "string" },
        "weight": { "type": "string" },
        "chosenProgram": { "type": "string" },
        "onboardingComplete": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "fcmTokens": { 
          "type": "array", 
          "items": { "type": "string" },
          "description": "List of FCM registration tokens for push notifications"
        }
      },
      "required": ["uid", "email", "role"]
    },
    "Workout": {
      "title": "Workout",
      "description": "A daily workout routine for a client.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string", "description": "UID of the client" },
        "weekNumber": { "type": "integer" },
        "dayNumber": { "type": "integer" },
        "exercises": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "youtubeLink": { "type": "string", "format": "uri" },
              "sets": { "type": "integer" },
              "reps": { "type": "string" },
              "weight": { "type": "string" },
              "rest": { "type": "string" },
              "coachNote": { "type": "string" }
            }
          }
        },
        "scheduledDate": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "weekNumber", "dayNumber", "exercises"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "Client feedback for a completed workout.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "workoutId": { "type": "string" },
        "weekNumber": { "type": "integer" },
        "dayNumber": { "type": "integer" },
        "completionStatus": { "type": "boolean" },
        "clientNote": { "type": "string" },
        "motivationalMessage": { "type": "string", "description": "AI generated message" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "workoutId", "completionStatus"]
    },
    "Template": {
      "title": "Workout Template",
      "description": "A reusable workout routine template.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "category": { "type": "string" },
        "description": { "type": "string" },
        "exercises": {
          "type": "array",
          "items": { "$ref": "Workout.properties.exercises.items" }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "exercises"]
    },
    "Message": {
      "title": "Message",
      "description": "A direct message between an admin and a client.",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "receiverId": { "type": "string" },
        "text": { "type": "string" },
        "isRead": { "type": "boolean" },
        "type": { "type": "string", "enum": ["chat", "motivation", "reminder"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "receiverId", "text", "type"]
    },
    "Metric": {
      "title": "Body Metric",
      "description": "Daily body metrics tracked by the client.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "waterIntake": { "type": "integer" },
        "stepCount": { "type": "integer" },
        "calories": { "type": "integer" },
        "weight": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "date", "waterIntake", "stepCount", "calories"]
    },
    "Habit": {
      "title": "Habit",
      "description": "A recurring habit defined for a client.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "frequency": { "type": "string", "enum": ["daily", "weekly"] },
        "category": { "type": "string" },
        "icon": { "type": "string" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "title", "frequency", "active"]
    },
    "HabitLog": {
      "title": "Habit Log",
      "description": "Completion record for a habit on a specific date.",
      "type": "object",
      "properties": {
        "habitId": { "type": "string" },
        "clientId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "completed": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["habitId", "clientId", "date", "completed"]
    },
    "Goal": {
      "title": "Goal",
      "description": "A specific fitness or health goal for a client.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "targetValue": { "type": "number" },
        "currentValue": { "type": "number" },
        "unit": { "type": "string" },
        "deadline": { "type": "string", "format": "date" },
        "category": { "type": "string" },
        "status": { "type": "string", "enum": ["in-progress", "completed", "deferred"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "title", "status"]
    },
    "MessageTemplate": {
      "title": "Message Template",
      "description": "A reusable motivational or reminder message template.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "category": { "type": "string", "enum": ["motivation", "reminder", "general"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "content", "category"]
    },
    "Reminder": {
      "title": "Reminder",
      "description": "A personal reminder for habits or tasks.",
      "type": "object",
      "properties": {
        "clientId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "time": { "type": "string", "description": "HH:mm format" },
        "days": { "type": "array", "items": { "type": "integer" } },
        "habitId": { "type": "string" },
        "goalId": { "type": "string" },
        "active": { "type": "boolean" },
        "type": { "type": "string", "enum": ["habit", "goal", "task"] },
        "lastNotified": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["clientId", "title", "time", "active", "type"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "User",
      "description": "User profiles and roles"
    },
    "/workouts/{workoutId}": {
      "schema": "Workout",
      "description": "Workout routines assigned to clients"
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "Client feedback and completion tracking"
    },
    "/templates/{templateId}": {
      "schema": "Template",
      "description": "Reusable workout templates"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Direct messages between admins and clients"
    },
    "/metrics/{metricId}": {
      "schema": "Metric",
      "description": "Daily body metrics tracked by clients"
    },
    "/habits/{habitId}": {
      "schema": "Habit",
      "description": "Habits defined for clients"
    },
    "/habitLogs/{logId}": {
      "schema": "HabitLog",
      "description": "Daily completion logs for habits"
    },
    "/goals/{goalId}": {
      "schema": "Goal",
      "description": "Personalized fitness goals for clients"
    },
    "/messageTemplates/{templateId}": {
      "schema": "MessageTemplate",
      "description": "Reusable message templates for admins"
    },
    "/reminders/{reminderId}": {
      "schema": "Reminder",
      "description": "Personal reminders for habits and tasks"
    }
  }
}
